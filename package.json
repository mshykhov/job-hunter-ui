    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@tanstack/react-query": "^5.90.21",
    "antd": "^6.3.1",
    "axios": "^1.13.5",
    "dompurify": "^3.3.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable": "^3.1.3",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
